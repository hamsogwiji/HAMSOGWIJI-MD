# ═══════════════════════════════════════════════════════════════════
# GWIJITECH-MD BOT CONFIGURATION
# All settings can be controlled via these environment variables
# ═══════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────
# REQUIRED SETTINGS
# ─────────────────────────────────────────────────────────────────
OWNER_NUMBER=
SESSION=

# ─────────────────────────────────────────────────────────────────
# BOT SETTINGS
# ─────────────────────────────────────────────────────────────────
BOT_NAME=𝐆𝐖𝐈𝐉𝐈𝐓𝐄𝐂𝐇 𝐌𝐃
PREFIX=.
MODE=public
PACKNAME=𝐆𝐖𝐈𝐉𝐈𝐓𝐄𝐂𝐇 𝐌𝐃
TIMEZONE=Africa/Nairobi
AUTHOR=Bakari Hamso
DEVICE_MODE=Android

# ─────────────────────────────────────────────────────────────────
# ANTI-CALL SETTINGS
# ANTI_CALL: on/off
# ANTI_CALL_ACTION: reject/block
# ANTI_CALL_MSG: Message sent when rejecting calls
# ─────────────────────────────────────────────────────────────────
ANTI_CALL=off
ANTI_CALL_ACTION=reject
ANTI_CALL_MSG=Call me later

# ─────────────────────────────────────────────────────────────────
# ANTI-DELETE SETTINGS
# ANTI_DELETE: on/off
# ─────────────────────────────────────────────────────────────────
ANTI_DELETE=on

# ─────────────────────────────────────────────────────────────────
# ANTI-LINK SETTINGS
# ANTI_LINK: off/warn/delete/remove
# WARN_LIMIT: Number of warnings before action
# ─────────────────────────────────────────────────────────────────
ANTI_LINK=on
WARN_LIMIT=6

# ─────────────────────────────────────────────────────────────────
# ANTI-TAG/STATUS MENTION SETTINGS
# ANTI_TAG: off/warn/delete/remove
# ─────────────────────────────────────────────────────────────────
ANTI_TAG=off

# ─────────────────────────────────────────────────────────────────
# AUTO-READ SETTINGS
# AUTO_READ: on/off
# ─────────────────────────────────────────────────────────────────
AUTO_READ=off

# ─────────────────────────────────────────────────────────────────
# AUTO-BIO SETTINGS
# AUTO_BIO: on/off
# ─────────────────────────────────────────────────────────────────
AUTO_BIO=off

# ─────────────────────────────────────────────────────────────────
# AUTO STATUS SETTINGS
# AUTO_STATUS_VIEW: on/off
# AUTO_STATUS_LIKE: on/off
# AUTO_STATUS_REPLY: on/off
# STATUS_REPLY_MSG: Message for auto-reply
# STATUS_LIKE_EMOJIS: Comma-separated emojis
# ─────────────────────────────────────────────────────────────────
AUTO_STATUS_VIEW=on
AUTO_STATUS_LIKE=on
AUTO_STATUS_REPLY=off
STATUS_REPLY_MSG=Nice status! Viewed by 𝐺𝑊𝐼𝐽𝐼𝑇𝐸𝐶𝐻-𝑀𝐷 Bot
STATUS_LIKE_EMOJIS=❤️,💜,💙,🤍,💛

# ─────────────────────────────────────────────────────────────────
# CHATBOT SETTINGS
# CHATBOT: on/off
# CHATBOT_MODE: private/group/both
# CHATBOT_TRIGGER: Trigger word
# CHATBOT_RESPONSE: text/audio
# CHATBOT_VOICE: Voice for audio (Kimberly, Salli, Joey, etc)
# ─────────────────────────────────────────────────────────────────
CHATBOT=off
CHATBOT_MODE=private
CHATBOT_TRIGGER=dm
CHATBOT_RESPONSE=text
CHATBOT_VOICE=Kimberly

# ─────────────────────────────────────────────────────────────────
# PRESENCE SETTINGS
# PRESENCE_PRIVATE: on/online/typing/recording
# PRESENCE_GROUP: on/online/typing/recording
# ─────────────────────────────────────────────────────────────────
PRESENCE_PRIVATE=on
PRESENCE_GROUP=on

# ─────────────────────────────────────────────────────────────────
# MENU STYLING
# ─────────────────────────────────────────────────────────────────
BOT_URL=https://files.catbox.moe/gp80fz.jpg
MENU_TOP_LEFT=*╭━━━━━╼⚬*
MENU_BOT_NAME_LINE=*│
MENU_BOTTOM_LEFT=*╰╼⚬*
MENU_GREETING_LINE=   *▏
MENU_DIVIDER=   *╰━━━━━╼⚬
MENU_USER_LINE=> 🕵️
MENU_DATE_LINE=> 📅
MENU_TIME_LINE=> ⏰
MENU_STATS_LINE=> ⭐
MENU_BOTTOM_DIVIDER=⚬╼━━━━━━━━━━━━╾⚬

# ─────────────────────────────────────────────────────────────────
# DATABASE (optional - uses SQLite if not set)
# ─────────────────────────────────────────────────────────────────
# DATABASE_URL=postgres://user:password@host:port/database