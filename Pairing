<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Loading Screen</title>
  <style>
    body {
      margin: 0;
      background-color: #000;
      color: #0f0;
      font-family: monospace;
      overflow: hidden;
    }

    .loader {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      text-align: center;
      border: 2px solid #0f0;
      padding: 20px;
      width: 80%;
      max-width: 500px;
    }

    .loader .spinner {
      font-size: 40px;
      margin-bottom: 20px;
      animation: blink 1.5s infinite;
    }

    @keyframes blink {
      0% { opacity: 1; }
      50% { opacity: 0; }
      100% { opacity: 1; }
    }

    .loader .text {
      font-size: 18px;
      line-height: 1.5;
    }

    .pairing-code {
      display: none;
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      text-align: center;
      color: #0f0;
      border: 2px solid #0f0;
      padding: 20px;
      width: 80%;
      max-width: 500px;
    }

    .pairing-code input {
      margin: 10px 0;
      padding: 10px;
      border: none;
      border-radius: 5px;
      width: 100%;
      background-color: #000;
      color: #0f0;
      border: 1px solid #0f0;
    }

    .pairing-code button {
      background-color: #0f0;
      color: #000;
      padding: 10px 20px;
      border: none;
      border-radius: 5px;
      cursor: pointer;
    }
  </style>
</head>
<body>
  <div class="loader">
    <div class="spinner">( )</div>
    <div class="text">
      INITIALIZING GWIJITECH XMD PAIRING CODE.<br>
      <hr style="border-color:        
      GWIJITECH XMD HOSTING PLATINUM<br>
      Quantum Server Initialisation..<br>
      Premium Hosting Services Active<br>
      v1.0.0 Platinum
    </div>
  </div>

  <div class="pairing-code">
    <h2>Enter WhatsApp Pairing Code</h2>
    <input type="number" placeholder="Pairing Code" />
    <button>Submit</button>
  </div>

  <script>
    setTimeout(() => {
      document.querySelector('.loader').style.display = 'none';
      document.querySelector('.pairing-code').style.display = 'block';
    }, 5000); // 5 seconds
  </script>
</body>
</html>
